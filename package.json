{
  "name": "peekom",
  "version": "1.2.0",
  "description": "Peekom — edge memo app with optional Plus upgrade",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "predist": "node scripts/generate-icon-ico.mjs && node scripts/prepare-dist.js",
    "dist": "npm run predist && electron-builder --win nsis",
    "dist:win": "electron-builder --win nsis",
    "dist:win:unsigned": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis",
    "dist:publish": "electron-builder --win nsis --publish always"
  },
  "keywords": [
    "electron",
    "presentation",
    "peekom",
    "memo"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nannie-99/peekom-landing.git"
  },
  "build": {
    "appId": "com.peekom.app",
    "productName": "Peekom",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "license.js",
      "updater.js",
      "index.html",
      "settings.html",
      "assets/**/*",
      "build/icon.ico",
      "build/plus.ico",
      "build/index.png",
      "build/plus.png",
      "package.json",
      "node_modules/marked/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/graceful-fs/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lodash.escaperegexp/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/semver/**/*",
      "node_modules/tiny-typed-emitter/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/index.png",
        "to": "index.png"
      },
      {
        "from": "build/plus.png",
        "to": "plus.png"
      },
      {
        "from": "build/plus.ico",
        "to": "plus.ico"
      }
    ],
    "icon": "icon.ico",
    "afterPack": "scripts/embed-win-icon.js",
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Peekom-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Peekom",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Nannie-99",
        "repo": "peekom-landing"
      }
    ]
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1",
    "rcedit": "^4.0.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "marked": "^18.0.5"
  }
}
